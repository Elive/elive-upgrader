#!/bin/bash
SOURCE="$0"
source /usr/lib/elive-tools/functions
if el_check_version_is_days_recent 120; then
    export FORCE_REPORTS="1"
    export NOREPORTS="0"
    export EL_REPORTS="1"
else
    export FORCE_REPORTS="0"
    export NOREPORTS="1"
    export EL_REPORTS="0"
fi
el_make_environment

# wrapper for fix strange languages
locales_source(){
    if [[ -s "/etc/default/locale" ]] ; then
        source /etc/default/locale
    fi
    # wrapper for fix strange languages
    case "$LANG" in
        am*|ar*|bg*|bn*|el*|fa*|gu*|he*|hy*|hi*|iw*|ja*|ka*|kn*|ko*|ml*|mr*|ne*|pa*|ru*|sr*|ta*|te*|th*|uk*|vi*|zh*)
            export LC_ALL=en_US.UTF-8
            export LANG=en_US.UTF-8
            ;;
    esac
}
locales_source

. gettext.sh
TEXTDOMAIN="elive-upgrader"
export TEXTDOMAIN


#
# elive-boot-upgrader - Handles boot-time Debian distribution upgrades
#
# This script is called by the init.d or systemd service during boot
# to perform the actual upgrade process.
#
# Hooks processed on first boot:
#   - debian-upgrade-packages-to-remove-if-not-before.txt
#     List of packages to remove after the first boot of the upgraded system
#     if they were not present before the upgrade. Supports wildcards.
#

set -e

source /usr/lib/elive-tools/functions 2>/dev/null || true

# Fallback if elive-tools functions are not available
if ! command -v el_error &>/dev/null; then
    el_error() { echo "ERROR: $*" >&2; }
fi
if ! command -v el_warning &>/dev/null; then
    el_warning() { echo "WARNING: $*" >&2; }
fi

DEFAULTS_FILE="/etc/default/elive-distro-upgrade"
LOCK_FILE="/tmp/.debian-upgrader.lock"
SCRIPT_PATH="/usr/lib/elive-upgrader/debian-upgrader"

# Map Debian version numbers to codenames
debian_version_to_codename() {
    local version="$1"
    case "$version" in
        15|15.*)  echo "duke" ;;
        14|14.*)  echo "forky" ;;
        13|13.*)  echo "trixie" ;;
        12|12.*)  echo "bookworm" ;;
        11|11.*)  echo "bullseye" ;;
        10|10.*)  echo "buster" ;;
        9|9.*)    echo "stretch" ;;
        8|8.*)    echo "jessie" ;;
        7|7.*)    echo "wheezy" ;;
        *)
            # Fallback: try to extract codename from version string
            echo "$version" | grep -oE '^[a-z]+' | head -1
            ;;
    esac
}

# Get current Debian codename
get_current_codename() {
    local current_release_full
    current_release_full="$(cat /etc/debian_version 2>/dev/null || echo "unknown")"
    local current_version_number
    current_version_number="$(echo "$current_release_full" | cut -d'.' -f1)"
    debian_version_to_codename "$current_version_number"
}

# Check if the upgrade target has already been reached
upgrade_check_target_reached() {
    local target="$1"
    local current_codename
    current_codename="$(get_current_codename)"

    if [ -n "$current_codename" ] && [ "$current_codename" = "$target" ]; then
        return 0  # Target reached
    fi
    return 1  # Target not reached
}

# Disable boot upgrade services (both systemd and sysvinit)
disable_boot_services() {
    # Disable systemd service in the background to prevent systemd from hanging/blocking this script
    if command -v systemctl &>/dev/null; then
        (
            sleep 2
            systemctl disable elive-distro-upgrader.service 2>/dev/null || true
            systemctl daemon-reload 2>/dev/null || true
        ) &
    fi
    # Disable sysvinit script
    if command -v update-rc.d &>/dev/null; then
        update-rc.d -f elive-distro-upgrader remove 2>/dev/null || true
    fi
}

# Suspend TTY logins on non-systemd systems
suspend_non_systemd_gettys() {
    if [ ! -d /run/systemd/system ]; then
        echo "Non-systemd system detected. Suspending TTY logins..."
        # For SysVinit: comment out getty lines in /etc/inittab
        if [ -f /etc/inittab ]; then
            cp -a /etc/inittab /etc/inittab.bak-upgrader 2>/dev/null || true
            sed -i 's/^\([0-9]\+:.*getty.*\)/#DISABLED-BY-UPGRADER#\1/' /etc/inittab 2>/dev/null || true
            # Tell init to reload inittab
            telinit q 2>/dev/null || kill -HUP 1 2>/dev/null || true
        fi
        # For OpenRC: stop getty services
        if command -v rc-service &>/dev/null; then
            for srv in $(rc-status --all 2>/dev/null | grep getty | awk '{print $1}'); do
                rc-service "$srv" stop 2>/dev/null || true
            done
        fi
    fi
}

# Restore TTY logins on non-systemd systems
restore_non_systemd_gettys() {
    if [ ! -d /run/systemd/system ]; then
        echo "Restoring TTY logins..."
        # For SysVinit: restore getty lines in /etc/inittab
        if [ -f /etc/inittab.bak-upgrader ]; then
            mv -f /etc/inittab.bak-upgrader /etc/inittab 2>/dev/null || true
            telinit q 2>/dev/null || kill -HUP 1 2>/dev/null || true
        elif [ -f /etc/inittab ]; then
            sed -i 's/^#DISABLED-BY-UPGRADER#//' /etc/inittab 2>/dev/null || true
            telinit q 2>/dev/null || kill -HUP 1 2>/dev/null || true
        fi
        # For OpenRC: start getty services
        if command -v rc-service &>/dev/null; then
            for srv in $(rc-status --all 2>/dev/null | grep getty | awk '{print $1}'); do
                rc-service "$srv" start 2>/dev/null || true
            done
        fi
    fi
}

process_remove_if_not_before() {
    local target_codename="$1"
    local pkgs_before_file="/var/log/elive-upgrader/debian-upgrade-packages-before-${target_codename}.txt"

    if [ ! -f "$pkgs_before_file" ]; then
        echo "No packages-before file found at $pkgs_before_file, skipping remove-if-not-before check."
        return 0
    fi

    local pending_list="/var/cache/elive-upgrader/pending-remove-if-not-before.txt"
    if [ ! -f "$pending_list" ]; then
        echo "No pending remove-if-not-before hooks found."
        return 0
    fi

    local hook_file
    while read -r hook_file; do
        [ -z "$hook_file" ] && continue
        if [ -f "$hook_file" ]; then
            echo "Processing remove-if-not-before hook: $hook_file"
            local pattern
            while read -r pattern; do
                # Skip comments and empty lines
                [ -z "$pattern" ] && continue
                case "$pattern" in
                    \#*) continue ;;
                esac

                # Remove trailing wildcard * for searching in the packages-before file
                local search_pattern="${pattern%\*}"

                # Check if search_pattern matches any package in pkgs_before_file
                if ! grep -q "^${search_pattern}" "$pkgs_before_file"; then
                    echo "Package pattern '$pattern' (search: '$search_pattern') was not present before upgrade. Removing..."
                    TERM=linux DEBIAN_FRONTEND=noninteractive DEBIAN_PRIORITY=critical DEBCONF_NONINTERACTIVE_SEEN=true DEBCONF_NOWARNINGS=true apt-get -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" remove --purge "$pattern" || true
                else
                    echo "Package pattern '$pattern' (search: '$search_pattern') was present before upgrade. Keeping."
                fi
            done < "$hook_file"
        fi
    done < "$pending_list"
    rm -f "$pending_list"
}

# Clean up state and disable services
cleanup_and_disable() {
    echo "Cleaning up upgrade state and disabling boot services"
    rm -f "$DEFAULTS_FILE"
    rm -f "$LOCK_FILE"
    disable_boot_services
    restore_non_systemd_gettys
}

# Validate the upgrade state before proceeding
validate_upgrade_state() {
    # Read configuration
    if [ ! -r "$DEFAULTS_FILE" ]; then
        echo "State file not found or not readable: $DEFAULTS_FILE"
        return 1
    fi

    # Source the defaults file
    . "$DEFAULTS_FILE"

    # Check required variables
    if [ "$UPGRADE_ENABLED" != "yes" ]; then
        echo "UPGRADE_ENABLED is not yes (value: \"$UPGRADE_ENABLED\"), cleaning up state file"
        cleanup_and_disable
        return 1
    fi

    # Check if target already reached and marked as completed
    if [ "$UPGRADE_COMPLETED" = "yes" ] && upgrade_check_target_reached "$TARGET_CODENAME"; then
        echo "Target $TARGET_CODENAME already reached and completed. Running post-boot hooks and cleaning up."
        process_remove_if_not_before "$TARGET_CODENAME"
        cleanup_and_disable
        return 1
    fi

    if [ "$UPGRADE_IN_PROGRESS" != "yes" ]; then
        if [ "$UPGRADE_COMPLETED" = "yes" ]; then
            echo "First boot of the new upgraded system detected. Running post-boot hooks..."
            process_remove_if_not_before "$TARGET_CODENAME"
        fi
        echo "UPGRADE_IN_PROGRESS is not yes (value: \"$UPGRADE_IN_PROGRESS\"), cleaning up state file"
        cleanup_and_disable
        return 1
    fi

    if [ -z "$TARGET_CODENAME" ]; then
        echo "TARGET_CODENAME is empty, cleaning up malformed state file"
        cleanup_and_disable
        return 1
    fi

    # Safety: enforce reboot limit to prevent infinite loops
    if [ "${REBOOT_COUNT:-0}" -ge 5 ] 2>/dev/null; then
        el_error "Too many reboots during upgrade (${REBOOT_COUNT:-0}). Aborting to prevent infinite loop."
        echo "Check logs at /var/log/debian-upgrade-*.log for details."
        cleanup_and_disable
        return 1
    fi

    # Clean up any stale lock files from crashed upgrades
    rm -f "$LOCK_FILE" 2>/dev/null || true

    return 0
}

# Main execution
main() {
    echo "=== Elive Boot Upgrader ==="
    echo "Starting at $(date)"

    # Validate state before proceeding
    if ! validate_upgrade_state; then
        echo "Validation failed or upgrade not needed. Exiting."
        exit 0
    fi

    # Suspend TTY logins for non-systemd systems
    suspend_non_systemd_gettys

    # Re-read config after validation (in case it was modified)
    . "$DEFAULTS_FILE"

    local current_cn
    current_cn="$(get_current_codename)"
    echo "Validated: upgrading from ${current_cn:-unknown} to $TARGET_CODENAME"

    # Check if upgrade script exists
    if [ ! -x "$SCRIPT_PATH" ]; then
        el_error "$SCRIPT_PATH not found or not executable"
        cleanup_and_disable
        exit 1
    fi

    # Run the upgrade
    echo "Starting upgrade to $TARGET_CODENAME"
    set +e
    local err_log
    err_log=$(mktemp)
    "$SCRIPT_PATH" --boot-mode "$TARGET_CODENAME" 2> "$err_log"
    local exit_code=$?
    set -e

    # Handle exit code
    if [ "$exit_code" -ne 0 ]; then
        # If the exit code indicates a signal termination (e.g. SIGTERM 143, SIGINT 130)
        # or if the system is currently shutting down/rebooting, do NOT cancel the upgrade.
        # Just exit and let it resume on the next boot.
        if [ "$exit_code" -eq 143 ] || [ "$exit_code" -eq 130 ] || [ -f /run/systemd/shutdown/scheduled ] || [ -f /run/systemd/shutdown ]; then
            echo "Upgrade process was interrupted by system shutdown/reboot (exit code $exit_code). Preserving state for next boot."
            exit 0
        fi

        local err_msg
        err_msg=$(cat "$err_log" 2>/dev/null || true)
        rm -f "$err_log"

        # If empty due to script-level redirection, extract from the actual log file
        if [ -z "$err_msg" ]; then
            local latest_log
            latest_log=$(ls -t /var/log/debian-upgrade-*.log 2>/dev/null | head -n 1 || true)
            if [ -n "$latest_log" ] && [ -f "$latest_log" ]; then
                err_msg=$(grep -E "E:|Error:|Insufficient space|failed" "$latest_log" | tail -n 5 || tail -n 10 "$latest_log" || true)
            fi
        fi

        if [ -z "$err_msg" ]; then
            err_msg="Unknown error occurred during the boot upgrade process."
        fi

        el_error "Upgrade exited with code $exit_code. Last errors: $err_msg"
        echo "Check logs at /var/log/debian-upgrade-*.log for details"

        echo "Preserving upgrade state to resume on next boot (Reboot count: ${REBOOT_COUNT:-0}/5)"

        # Create a notification flag file so the user is notified of the failure upon login
        mkdir -p /var/lib/elive-upgrader 2>/dev/null || true
        echo "$err_msg" > /var/lib/elive-upgrader/last-boot-upgrade-failure 2>/dev/null || true

        # Set up recovery notification for desktop - user will be notified on next login
        # This creates an autostart entry that shows a recovery dialog
        if [ -x "$SCRIPT_PATH" ]; then
            "$SCRIPT_PATH" --setup-recovery-notification 2>/dev/null || true
        fi

        exit 0
    fi
    rm -f "$err_log"

    echo "Upgrade completed successfully at $(date)"

    # Check if state file still exists (debian-upgrader may have cleaned it up)
    if [ ! -f "$DEFAULTS_FILE" ]; then
        echo "State file removed by upgrade script - upgrade completed"
    else
        # Re-read and check state
        . "$DEFAULTS_FILE"
        if [ "$UPGRADE_IN_PROGRESS" = "no" ]; then
            echo "Upgrade marked as not in progress - cleaning up"
            cleanup_and_disable
        fi
    fi

    echo "Rebooting system to apply changes in 10 seconds..."
    sync
    ( sleep 10 ; sync ; reboot || /sbin/reboot || reboot -f ) &
    exit 0
}

# Run main function
main "$@"

            fi
            # 2. Run post-upgrade script
            if [[ -x "$hook_dir/debian-upgrade-post-script.sh" ]]; then
                log_info "Running post-upgrade script: $hook_dir/debian-upgrade-post-script.sh"
                "$hook_dir/debian-upgrade-post-script.sh" || true
            fi
        fi
    done

    case "$codename" in

                pkgs=$(cat "$hook_dir/debian-upgrade-packages-to-install.txt" | grep -v "^#" | tr '\n' ' ')
                if [[ -n "$pkgs" ]]; then
                    log_info "Installing supporting packages: $pkgs"
                    safe_apt_run apt-get install -y $pkgs || true
